<Project Sdk="WixToolset.Sdk/5.0.2">

  <PropertyGroup>
    <OutputType>Package</OutputType>
    <OutputName>Pacer-Setup</OutputName>
    <Platform>x64</Platform>
  </PropertyGroup>

  <ItemGroup>
    <!-- WixUI extension provides the standard InstallDir wizard UI -->
    <PackageReference Include="WixToolset.UI.wixext" Version="5.0.2" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Pacer.wxs" />
  </ItemGroup>

</Project>
